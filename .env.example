# ===== InvoiceGST Environment Variables =====
# Copy this file to .env and fill in your values.

# SMTP Configuration for Password Reset & Invoice Emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Default Admin (only used on first run to seed the database)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe@123

# Session secret (generate a random string)
# SESSION_SECRET=your-random-secret-key

# Firebase (optional — used if service-account.json is not present)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# FIREBASE_PROJECT_ID=your-project-id
